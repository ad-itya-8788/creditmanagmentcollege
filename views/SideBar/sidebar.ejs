<aside class="sidebar">
    <div class="sidebar-brand">
        <img src="/img/navlogoagri.png" alt="AgriCRM" onerror="this.style.display='none'">
    </div>

    <nav class="sidebar-nav">
        <div class="sidebar-section-label">Main Menu</div>

        <a href="/dashboard" class="sidebar-item <%= (typeof active !== 'undefined' && active === 'dashboard') ? 'active' : '' %>">
            <i class="fas fa-home"></i>
            <span>Dashboard</span>
        </a>

        <a href="/customers" class="sidebar-item <%= (typeof active !== 'undefined' && active === 'customers') ? 'active' : '' %>">
