<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/sidebar.css">

    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon-16x16.png">
    <link rel="manifest" href="/img/site.webmanifest">

    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
    <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet">

    <style>
        :root {
            --primary:   #1a6b3c;
            --success:   #16a34a;
            --danger:    #dc2626;
            --warning:   #d97706;
            --text:      #111827;
            --text-muted:#6b7280;
            --border:    #e5e7eb;
            --bg:        #f7f8fa;
            --white:     #ffffff;
            --radius:    8px;
            --shadow:    0 1px 4px rgba(0,0,0,0.07);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
        }

        .main-content { padding: 1rem 1.5rem 90px; }

        /* Shop Info */
        .shop-info {
            background: var(--white);
            border: 1px solid var(--border);
            border-left: 4px solid var(--primary);
            border-radius: var(--radius);
            padding: 0.9rem 1.2rem;
            margin-bottom: 1rem;
        }
        .shop-name  { font-size: 1rem; font-weight: 700; margin-bottom: 0.2rem; }
        .shop-details { font-size: 0.82rem; color: var(--text-muted); }

        /* Summary Table */
        .summary-wrap {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            margin-bottom: 1rem;
            box-shadow: var(--shadow);
        }
        .summary-wrap table { width: 100%; border-collapse: collapse; }
        .summary-wrap thead tr { background: #f0fdf4; }
        .summary-wrap th {
            padding: 0.5rem 1rem;
            font-size: 0.65rem; font-weight: 700; color: #374151;
            text-transform: uppercase; letter-spacing: 0.5px;
            border-right: 1px solid var(--border);
            border-bottom: 2px solid #d1fae5;
            white-space: nowrap;
        }
        .summary-wrap th:last-child { border-right: none; }
        .summary-wrap td {
            padding: 0.65rem 1rem;
            font-size: 1.35rem; font-weight: 800;
            border-right: 1px solid #f3f4f6;
        }
        .summary-wrap td:last-child { border-right: none; }

        /* Filter Toolbar */
        .filter-toolbar {
            display: flex; align-items: center; gap: 0.5rem;
            flex-wrap: wrap; margin-bottom: 0.6rem;
        }
        .rpt-search {
            display: flex; align-items: center; gap: 0.35rem;
            background: var(--white); border: 1px solid var(--border);
            border-radius: 6px; padding: 0.28rem 0.65rem;
            flex: 1; min-width: 160px;
        }
        .rpt-search i { color: #9ca3af; font-size: 0.72rem; }
        .rpt-search input {
            border: none; outline: none; width: 100%;
            font-size: 0.75rem; font-family: 'Poppins', sans-serif;
            background: transparent; color: var(--text);
        }
        .filter-pills { display: flex; gap: 0.4rem; margin-left: auto; }
        .fp-btn {
            background: #f9fafb; color: #374151;
            border: 1px solid #d1d5db;
            padding: 0.3rem 0.75rem; border-radius: 6px;
            cursor: pointer; font-size: 0.72rem; font-weight: 600;
            font-family: 'Poppins', sans-serif; transition: all 0.15s;
        }
        .fp-btn.active { background: var(--primary); color: var(--white); border-color: var(--primary); }
        .fp-btn:hover:not(.active) { border-color: var(--primary); color: var(--primary); }

        /* Customer Table */
        .table-wrap {
            border: 1px solid #d1d5db;
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow);
        }
        .customer-table {
            width: 100%; border-collapse: collapse;
            font-size: 0.78rem; background: var(--white);
            table-layout: fixed;
        }
        .customer-table thead tr { background: #f0fdf4; }
        .customer-table th {
            padding: 0.6rem 0.85rem;
            font-size: 0.66rem; font-weight: 700; color: #1f2937;
            text-transform: uppercase; letter-spacing: 0.5px;
            border-right: 1px solid #d1d5db;
            border-bottom: 2px solid #86efac;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .customer-table th:last-child { border-right: none; }
        .customer-table td {
            padding: 0.55rem 0.85rem;
            border-bottom: 1px solid var(--border);
            border-right: 1px solid var(--border);
            vertical-align: middle;
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        }
        .customer-table td:last-child { border-right: none; }
        .customer-table tbody tr:last-child td { border-bottom: none; }
        .customer-table tbody tr:nth-child(even) { background: #fafafa; }
        .customer-table tbody tr:hover { background: #f0fdf4; }

        .customer-name   { font-weight: 700; }
        .customer-mobile { color: #374151; font-weight: 500; cursor: pointer; }
        .customer-village{ color: var(--text-muted); font-size: 0.82rem; }

        .amount-cell    { text-align: right; font-weight: 700; }
        .amount-total   { color: var(--primary); }
        .amount-pending { color: var(--danger); }

        .status-badge { padding: 3px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; }
        .status-clear   { background: rgba(40,167,69,.1); color: var(--success); }
        .status-pending { background: rgba(255,193,7,.1); color: var(--warning); }

        /* Payment / Due date cells */
        .payment-date {
            font-size: 0.82rem; font-weight: 500;
            padding: 0.2rem 0.45rem; border-radius: 4px;
            display: inline-block; min-width: 80px; text-align: center;
            color: var(--success); background: #e8f5e8; border: 1px solid var(--success);
        }
        .payment-date.no-date { color: var(--text-muted); background: none; border-color: transparent; }

        .due-date {
            font-size: 0.82rem; font-weight: 500;
            padding: 0.2rem 0.45rem; border-radius: 4px;
            display: inline-block; min-width: 80px; text-align: center;
        }
        .due-date.overdue  { color: var(--danger);  background: #ffe6e6; border: 1px solid var(--danger); }
        .due-date.today    { color: var(--warning);  background: #fff3cd; border: 1px solid var(--warning); }
        .due-date.clear    { color: var(--text-muted); }
        .due-date.no-date  { color: var(--text-muted); font-style: italic; }
        .overdue-badge, .today-badge { display: block; font-size: 0.68rem; font-weight: 700; margin-top: 0.1rem; }
        .overdue-badge { color: var(--danger); }
        .today-badge   { color: var(--warning); }

        /* Empty state */
        .empty-state { text-align: center; padding: 3rem 1rem; color: var(--text-muted); }
        .empty-state .empty-icon  { font-size: 3.5rem; opacity: 0.5; margin-bottom: 0.75rem; }
        .empty-state .empty-title { font-size: 1.2rem; font-weight: 600; color: var(--text); margin-bottom: 0.4rem; }

        /* Copy toast */
        #copyToast {
            position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%);
            background: #111827; color: #fff;
            padding: 0.4rem 1rem; border-radius: 20px;
            font-size: 0.78rem; font-weight: 500;
            opacity: 0; pointer-events: none; transition: opacity 0.2s;
            z-index: 9999;
        }
        #copyToast.show { opacity: 1; }

        @media (max-width: 768px) {
            .main-content { padding: 1rem; padding-bottom: 100px; }
            .customer-table { font-size: 0.75rem; min-width: 700px; }
            .customer-table th, .customer-table td { padding: 0.5rem 0.5rem; }
        }
    </style>
</head>
<body class="sidebar-layout">
    <%- include('SideBar/sidebar', {active: 'report'}) %>
    <div class="page-topbar">
        <div class="page-topbar-title"><i class="fas fa-chart-bar"></i> Customer Reports</div>
    </div>

    <main class="main-content">

        <!-- Shop Info -->
        <div class="shop-info">
            <div class="shop-name"><%= user.shop_name || 'AgriCRM Shop' %></div>
            <div class="shop-details">
                <% if (user.owner_name)  { %>Owner: <%= user.owner_name %><% } %>
                <% if (user.owner_phone) { %> | Phone: <%= user.owner_phone %><% } %>
                <% if (user.district)    { %> | <%= user.district %><%= user.tehsil ? ', ' + user.tehsil : '' %><% } %>
            </div>
        </div>

        <!-- Summary Row -->
        <div class="summary-wrap">
            <table>
                <thead>
                    <tr>
                        <th><i class="fas fa-users" style="color:#1a6b3c;margin-right:4px;"></i>Total Customers</th>
                        <th><i class="fas fa-check-circle" style="color:#16a34a;margin-right:4px;"></i>Clear</th>
                        <th><i class="fas fa-clock" style="color:#dc2626;margin-right:4px;"></i>Pending</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="color:#1a6b3c;"><%= totalCustomers %></td>
                        <td style="color:#16a34a;"><%= totalClear %></td>
                        <td style="color:#dc2626;"><%= totalPending %></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Filter Toolbar -->
        <div class="filter-toolbar">
            <div class="rpt-search">
                <i class="fas fa-search"></i>
                <input type="text" id="rptSearch" placeholder="Search by name or phone..." oninput="searchReport()">
            </div>
            <div class="filter-pills">
                <button class="fp-btn active" data-filter="all"><i class="fas fa-list"></i> All</button>
                <button class="fp-btn" data-filter="clear"><i class="fas fa-check-circle"></i> Clear</button>
                <button class="fp-btn" data-filter="pending"><i class="fas fa-clock"></i> Pending</button>
            </div>
        </div>

        <!-- Customer Table -->
        <div class="table-wrap">
            <table class="customer-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Mobile</th>
                        <th>Village</th>
                        <th>Total Amount</th>
                        <th>Pending Amount</th>
                        <th>First Payment</th>
                        <th>Next Due</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody id="customerTableBody">
                    <%
                    const allCustomers = [];
                    (clearCustomers   || []).forEach(c => allCustomers.push({ ...c, status: 'clear',   pending_amount: 0 }));
                    (pendingCustomers || []).forEach(c => allCustomers.push({ ...c, status: 'pending' }));
                    %>

                    <% if (allCustomers.length > 0) { %>
                        <% allCustomers.forEach(function(customer) { %>
                            <tr class="customer-row"
                                data-status="<%= customer.status %>"
                                data-name="<%= (customer.name || '').toLowerCase() %>"
                                data-mobile="<%= customer.mobile_number || '' %>">

                                <td><div class="customer-name"><%= customer.name || 'N/A' %></div></td>

                                <td>
                                    <div class="customer-mobile" title="Click to copy" onclick="copyMobile(this)">
                                        <%= customer.mobile_number || 'N/A' %>
                                    </div>
                                </td>

                                <td><div class="customer-village"><%= customer.village_city || 'N/A' %></div></td>

                                <td class="amount-cell amount-total">
                                    ₹<%= (customer.total_amount || 0).toLocaleString() %>
                                </td>

                                <td class="amount-cell <%= customer.status === 'pending' ? 'amount-pending' : '' %>">
                                    <% if (customer.status === 'pending') { %>
                                        ₹<%= (customer.pending_amount || 0).toLocaleString() %>
                                    <% } else { %>
                                        ₹0
                                    <% } %>
                                </td>

                                <td style="text-align:center;">
                                    <% if (customer.first_payment_date) { %>
                                        <div class="payment-date">
                                            <%= new Date(customer.first_payment_date).toLocaleDateString('en-IN') %>
                                        </div>
                                    <% } else { %>
                                        <div class="payment-date no-date">—</div>
                                    <% } %>
                                </td>

                                <td style="text-align:center;">
                                    <% if (customer.status === 'pending' && customer.next_due_date) { %>
                                        <%
                                        const dueDate   = new Date(customer.next_due_date);
                                        const today     = new Date();
                                        const isOverdue = dueDate < today;
                                        const isToday   = dueDate.toDateString() === today.toDateString();
                                        %>
                                        <div class="due-date <%= isOverdue ? 'overdue' : (isToday ? 'today' : '') %>">
                                            <%= dueDate.toLocaleDateString('en-IN') %>
                                            <% if (isOverdue) { %><span class="overdue-badge">Overdue</span><% } %>
                                            <% if (isToday)   { %><span class="today-badge">Today</span><% } %>
                                        </div>
                                    <% } else if (customer.status === 'pending') { %>
                                        <div class="due-date no-date">No Due Date</div>
                                    <% } else { %>
                                        <div class="due-date clear">—</div>
                                    <% } %>
                                </td>

                                <td>
                                    <span class="status-badge status-<%= customer.status %>">
                                        <%= customer.status === 'clear' ? 'Clear' : 'Pending' %>
                                    </span>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="8">
                                <div class="empty-state">
                                    <div class="empty-icon">📊</div>
                                    <div class="empty-title">No Customers Found</div>
                                    <div>No customer data available to display</div>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    </main>

    <!-- Copy toast -->
    <div id="copyToast">Copied!</div>

    <script>
        let currentFilter = 'all';

        /* Filter pill buttons */
        document.querySelectorAll('.fp-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.fp-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                currentFilter = this.getAttribute('data-filter');
                applyFilter();
            });
        });

        function applyFilter() {
            const q = (document.getElementById('rptSearch').value || '').toLowerCase().trim();
            document.querySelectorAll('.customer-row').forEach(row => {
                const matchStatus = currentFilter === 'all' || row.dataset.status === currentFilter;
                const matchSearch = !q || row.dataset.name.includes(q) || row.dataset.mobile.includes(q);
                row.style.display = (matchStatus && matchSearch) ? '' : 'none';
            });
        }

        function searchReport() { applyFilter(); }

        /* Click mobile number to copy */
        function copyMobile(el) {
            const text = el.textContent.trim();
            if (text === 'N/A') return;
            navigator.clipboard.writeText(text).then(() => {
                const toast = document.getElementById('copyToast');
                toast.classList.add('show');
                setTimeout(() => toast.classList.remove('show'), 1500);
            });
        }
    </script>
</body>
</html>
